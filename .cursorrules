<div className="grid gap-3 grid-cols-1 sm:grid-cols-2 lg:grid-cols-12">
  {/* Hero Action - 6 kolumn */}
  <div className="lg:col-span-6">...</div>

  {/* Stats - po 2 kolumny każda */}
